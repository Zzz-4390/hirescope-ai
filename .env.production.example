# Compose exposure. Keep loopback binding when a reverse proxy terminates TLS.
WEB_BIND_ADDRESS=127.0.0.1
WEB_PORT=3000

# PostgreSQL. URL-encode special characters in DATABASE_URL.
POSTGRES_DB=hirescope
POSTGRES_USER=hirescope
POSTGRES_PASSWORD=replace_with_a_strong_database_password
DATABASE_URL=postgresql://hirescope:replace_with_a_strong_database_password@postgres:5432/hirescope?schema=public

# Redis. REDIS_PASSWORD and the password embedded in REDIS_URL must match.
REDIS_PASSWORD=replace_with_a_strong_redis_password
REDIS_URL=redis://:replace_with_a_strong_redis_password@redis:6379/0
REDIS_COMMAND_TIMEOUT_MS=5000

# Shared upload/extraction storage and BullMQ recovery policy.
STORAGE_ROOT=/app/storage
TASK_QUEUE_NAME=hirescope-tasks
TASK_RECOVERY_INTERVAL_MS=30000
TASK_RECOVERY_BATCH_SIZE=100
TASK_RECOVERY_QUEUED_TIMEOUT_MS=60000
TASK_RECOVERY_PROCESSING_TIMEOUT_MS=300000
TASK_RECOVERY_MAX_ATTEMPTS=3

# Upload and analysis safety limits.
ZIP_MAX_BYTES=52428800
ZIP_MAX_FILES=5000
ZIP_MAX_SINGLE_FILE_BYTES=2097152
ZIP_MAX_EXTRACTED_BYTES=209715200
ZIP_MAX_DEPTH=30
ANALYSIS_MAX_TEXT_READ_BYTES=1048576

# DeepSeek-compatible provider. Keep AI_API_KEY only in the real .env.production.
AI_BASE_URL=https://api.deepseek.com
AI_API_KEY=replace_with_the_production_deepseek_api_key
AI_MODEL=deepseek-v4-flash

# Aliyun OSS for user profile avatars. Use a private bucket and least-privilege credentials.
OSS_ACCESS_KEY_ID=replace_with_the_production_oss_access_key_id
OSS_ACCESS_KEY_SECRET=replace_with_the_production_oss_access_key_secret
OSS_BUCKET=replace-with-private-bucket
OSS_REGION=oss-cn-hangzhou
OSS_SIGNED_URL_TTL_SECONDS=900

# API and browser security. CORS must be the exact public HTTPS origin.
NODE_ENV=production
API_HOST=0.0.0.0
API_PORT=3001
API_ORIGIN=http://api:3001
CORS_ALLOWED_ORIGINS=https://hirescope.example.com
TRUST_PROXY_HOPS=1

# Generate distinct secrets with at least 32 random bytes; do not reuse them.
JWT_ACCESS_SECRET=replace_with_at_least_32_random_bytes_for_jwt
JWT_ACCESS_TTL_SECONDS=900
JWT_ISSUER=hirescope-api
JWT_AUDIENCE=hirescope-web
AUTH_REFRESH_HASH_SECRET=replace_with_a_different_32_byte_refresh_secret
AUTH_REFRESH_TTL_SECONDS=2592000
AUTH_COOKIE_NAME=__Secure-hirescope_refresh
AUTH_DUMMY_PASSWORD_HASH='$argon2id$v=19$m=19456,t=2,p=1$EEPZnPvCwY5nfeXzD1KhIw$FhWXIFWMOeq3j3hNz5lERJAaD+u4VotBV8upTgifPcE'

# Password hashing and endpoint rate limits.
AUTH_ARGON2_MEMORY_KIB=19456
AUTH_ARGON2_TIME_COST=2
AUTH_ARGON2_PARALLELISM=1
AUTH_REGISTER_WINDOW_SECONDS=3600
AUTH_REGISTER_MAX_REQUESTS=5
AUTH_LOGIN_WINDOW_SECONDS=900
AUTH_LOGIN_MAX_REQUESTS=10
AUTH_REFRESH_WINDOW_SECONDS=300
AUTH_REFRESH_MAX_REQUESTS=30
