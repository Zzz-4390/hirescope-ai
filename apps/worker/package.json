{
  "name": "@hirescope/worker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "dev": "tsx --env-file=../../.env src/main.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run src",
    "test:integration": "tsx --env-file=../../.env test/run-integration-tests.ts"
  },
  "dependencies": {
    "@hirescope/shared-types": "workspace:*",
    "@prisma/client": "6.19.0",
    "bullmq": "^5.79.2",
    "ioredis": "^5.0.0",
    "yauzl": "^3.2.0"
  },
  "devDependencies": {
    "@types/yauzl": "^2.10.3",
    "@types/yazl": "^2.4.5",
    "prisma": "6.19.0",
    "tsx": "^4.0.0",
    "typescript": "5.9.3",
    "vitest": "^3.0.0",
    "yazl": "^3.3.1"
  }
}
